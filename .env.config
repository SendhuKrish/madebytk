# ─── App behaviour ────────────────────────────────────────────────────────────
# Safe to commit — no secrets here.
ENVIRONMENT=production
TZ=Asia/Singapore

# ─── Scheduler (APScheduler, all times in TZ above) ─────────────────────────
PREDICT_HOUR=8
PREDICT_MINUTE=0
RESULTS_HOUR=22
RESULTS_MINUTE=0
PREDICT_DAYS=mon,thu
RESULTS_DAYS=mon,thu

# ─── Scraper ─────────────────────────────────────────────────────────────────
SCRAPER_TIMEOUT=20
