# ════════════════════════════════════════════════════════════════════════════════
# MadeByTK Toto Engine — environment variable reference
#
# Copy into two files:
#   .env.config   — non-sensitive config (safe to commit to git)
#   .env.secret   — credentials and keys  (NEVER commit — gitignored)
#
# Both files are loaded automatically at startup (secrets override config on
# any variable that appears in both).
# ════════════════════════════════════════════════════════════════════════════════


# ── .env.secret — CREDENTIALS (never commit) ────────────────────────────────

# Anthropic Claude (for bet slip OCR)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (anon key for public reads, or service_role for full access)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── .env.config — NON-SENSITIVE CONFIG (safe to commit) ─────────────────────

# App behaviour
ENVIRONMENT=development
TZ=Asia/Singapore

# Scheduler (APScheduler, all times in TZ above)
PREDICT_HOUR=8
PREDICT_MINUTE=0
RESULTS_HOUR=22
RESULTS_MINUTE=0
PREDICT_DAYS=mon,thu
RESULTS_DAYS=mon,thu

# Scraper
SCRAPER_TIMEOUT=20
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; TotoEngine/3.0)

# Data Sources
SINGAPORE_POOLS_URL=https://www.singaporepools.com.sg/en/product/sr/Pages/toto_results.aspx
LOTTOLYZER_URL=https://en.lottolyzer.com/history/singapore/toto
LOTTERY_EXTREME_URL=https://www.lotteryextreme.com/singapore/toto-results
TOTO_API_URL=http://localhost:8100

# Claude AI
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024
PALLY_API_TIMEOUT=30
